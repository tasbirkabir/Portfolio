// Prisma schema for Tasbir Kabir — Digital HQ platform
// Uses PostgreSQL (Supabase) for production. Auth is handled by Supabase Auth.
// This Prisma schema manages content + profiles only (not auth users/sessions).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // For local dev: use "sqlite" with DATABASE_URL="file:./db/custom.db"
  // For Vercel/Supabase: change to "postgresql" and set DATABASE_URL to your Supabase connection string
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------- Content (sellable) ----------

model Book {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  subtitle     String
  description  String
  price        Float
  originalPrice Float?
  pages        Int
  category     String
  accent       String
  coverStyle   String
  badge        String?
  featured     Boolean  @default(false)
  rating       Float    @default(5)
  reviewsCount Int      @default(0)
  buyers       Int      @default(0)
  accessType   String   @default("paid")
  status       String   @default("published")
  whatYouLearn String   @default("[]")
  chapters     String   @default("[]")
  faq          String   @default("[]")
  highlights   String   @default("[]")
  content      String   @default("[]")
  seoTitle     String?
  seoDesc      String?
  assets       Asset[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Asset {
  id          String   @id @default(cuid())
  bookId      String
  book        Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  type        String
  label       String
  filename    String
  fileSize    Int
  fileType    String
  storagePath String
  downloads   Int      @default(0)
  createdAt   DateTime @default(now())
}

model Resource {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  type        String
  category    String
  accent      String
  price       Float    @default(0)
  accessType  String   @default("free")
  status      String   @default("published")
  downloads   Int      @default(0)
  pages       Int?
  fileUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String
  content     String
  category    String
  tags        String   @default("[]")
  readTime    Int
  cover       String
  featured    Boolean  @default(false)
  status      String   @default("published")
  seoTitle    String?
  seoDesc     String?
  publishedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Testimonial {
  id     String @id @default(cuid())
  name   String
  role   String
  quote  String
  rating Int    @default(5)
  bookSlug String?
  avatar String?
}

// ---------- Profiles (Supabase Auth handles users/sessions) ----------

// Profile links to Supabase auth.users by id (UUID).
// Stores app-specific data: role, display name, profile image.
model Profile {
  id           String    @id           // Matches Supabase auth.users.id (UUID)
  email        String    @unique
  name         String?
  role         String    @default("user") // user | admin
  profileImage String?
  banned       Boolean   @default(false)
  lastLoginAt  DateTime?
  lastLoginIp  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model LibraryAccess {
  id        String   @id @default(cuid())
  userId    String
  userEmail String
  itemType  String
  itemSlug  String
  createdAt DateTime @default(now())

  @@unique([userEmail, itemType, itemSlug])
}

model ReadingProgress {
  id           String  @id @default(cuid())
  userId       String
  bookSlug     String
  chapterIndex Int     @default(0)
  progress     Float   @default(0)
  updatedAt    DateTime @updatedAt

  @@unique([userId, bookSlug])
}

// ---------- Commerce ----------

model Order {
  id          String   @id @default(cuid())
  userId      String?
  userEmail   String
  userName    String?
  items       String
  total       Float
  currency    String   @default("USD")
  method      String
  status      String   @default("paid")
  txnId       String?
  createdAt   DateTime @default(now())
}

// ---------- Marketing ----------

model NewsletterSub {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  segment   String   @default("all")
  createdAt DateTime @default(now())
}

model Broadcast {
  id        String   @id @default(cuid())
  subject   String
  body      String
  segment   String   @default("all")
  status    String   @default("draft")
  sentAt    DateTime?
  createdAt DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  topic     String
  message   String
  createdAt DateTime @default(now())
}

